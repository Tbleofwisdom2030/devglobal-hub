    "express": "^4.19.0",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.0",
    "jsdom": "^24.1.0",
    "jsonwebtoken": "^9.0.2",
    "langchain": "^0.2.0",
    "multer": "^1.4.5-lts.1",
