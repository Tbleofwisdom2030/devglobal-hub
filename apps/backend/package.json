    "@langchain/core": "^0.2.0",
    "@langchain/openai": "^0.1.0",
    "@prisma/client": "^5.14.0",
    "@stripe/stripe-js": "^3.4.0",
    "@supabase/supabase-js": "^2.108.2",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.7.0",
    "compression": "^1.7.4",
