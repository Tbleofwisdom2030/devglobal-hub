generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  ADMIN
  SUPPORT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_ON_CUSTOMER
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ChatConversationStatus {
  ACTIVE
  CLOSED
  ARCHIVED
}

enum OrderStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum LicenseStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

enum KnowledgeContentType {
  FAQ
  DOCUMENTATION
  BLOG
  TUTORIAL
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String    @map("password_hash")
  fullName      String?   @map("full_name")
  avatarUrl     String?   @map("avatar_url")
  role          UserRole  @default(CUSTOMER)
  emailVerified Boolean   @default(false) @map("email_verified")
  lastLoginAt   DateTime? @map("last_login_at")
  bio           String?
  website       String?
  socialLinks   Json?     @map("social_links")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  orders            Order[]
  licenses          License[]
  supportTickets    SupportTicket[]
  chatConversations ChatConversation[]
  ticketMessages    TicketMessage[]
  auditLogs         AuditLog[]
  refreshTokens     RefreshToken[]
  blogComments      BlogComment[]

  @@index([email, role])
  @@map("users")
}

model Product {
  id              String   @id @default(uuid())
  slug            String   @unique
  name            String
  description     String?
  longDescription String?  @map("long_description")
  priceCents      Int      @map("price_cents")
  currency        String   @default("USD")
  category        String?
  tags            String[]
  imageUrls       String[] @map("image_urls")
  coverImage      String?  @map("cover_image")
  gallery         String[] @default([])
  features        Json     @default("[]")
  downloadUrl     String?  @map("download_url")
  version         String?
  changelog       String?
  isActive        Boolean  @default(true) @map("is_active")
  stripePriceId   String?  @map("stripe_price_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  orders        Order[]
  licenses      License[]
  supportTickets SupportTicket[]
  knowledgeBase KnowledgeBase[]

  @@index([isActive, category])
  @@map("products")
}

model Order {
  id              String      @id @default(uuid())
  userId          String      @map("user_id")
  productId       String      @map("product_id")
  stripeSessionId String?     @unique @map("stripe_session_id")
  stripePaymentId String?     @map("stripe_payment_id")
  amountCents     Int         @map("amount_cents")
  currency        String      @default("USD")
  status          OrderStatus @default(PENDING)
  metadata        Json        @default("{}")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product  @relation(fields: [productId], references: [id])
  license License?

  @@index([userId, status])
  @@map("orders")
}

model License {
  id              String        @id @default(uuid())
  userId          String        @map("user_id")
  productId       String        @map("product_id")
  orderId         String        @unique @map("order_id")
  licenseKey      String        @unique @map("license_key")
  status          LicenseStatus @default(ACTIVE)
  maxActivations  Int           @default(3) @map("max_activations")
  activationCount Int           @default(0) @map("activation_count")
  activatedAt     DateTime?     @map("activated_at")
  expiresAt       DateTime?     @map("expires_at")
  lastValidatedAt DateTime?     @map("last_validated_at")
  revokedReason   String?       @map("revoked_reason")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])
  order   Order   @relation(fields: [orderId], references: [id])

  @@index([userId, status])
  @@index([licenseKey])
  @@map("licenses")
}

model SupportTicket {
  id                String         @id @default(uuid())
  userId            String         @map("user_id")
  productId         String?        @map("product_id")
  subject           String
  status            TicketStatus   @default(OPEN)
  priority          TicketPriority @default(MEDIUM)
  category          String?
  aiSummary         String?        @map("ai_summary")
  aiSentiment       String?        @map("ai_sentiment")
  aiSuggestedAction String?        @map("ai_suggested_action")
  aiSimilarTickets  String[]       @map("ai_similar_tickets")
  assignedTo        String?        @map("assigned_to")
  resolvedAt        DateTime?      @map("resolved_at")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  user     User            @relation(fields: [userId], references: [id])
  product  Product?        @relation(fields: [productId], references: [id])
  messages TicketMessage[]

  @@index([userId, status])
  @@index([status, priority, createdAt(sort: Desc)])
  @@map("support_tickets")
}

model TicketMessage {
  id         String   @id @default(uuid())
  ticketId   String   @map("ticket_id")
  senderId   String   @map("sender_id")
  senderType String   @map("sender_type")
  content    String
  isInternal Boolean  @default(false) @map("is_internal")
  createdAt  DateTime @default(now()) @map("created_at")

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender User          @relation(fields: [senderId], references: [id])

  @@index([ticketId, createdAt])
  @@map("ticket_messages")
}

model ChatConversation {
  id            String                 @id @default(uuid())
  userId        String                 @map("user_id")
  title         String?
  status        ChatConversationStatus @default(ACTIVE)
  lastMessageAt DateTime?              @map("last_message_at")
  createdAt     DateTime               @default(now()) @map("created_at")
  updatedAt     DateTime               @updatedAt @map("updated_at")

  user     User          @relation(fields: [userId], references: [id])
  messages ChatMessage[]

  @@index([userId, status])
  @@map("chat_conversations")
}

model ChatMessage {
  id             String   @id @default(uuid())
  conversationId String   @map("conversation_id")
  senderType     String   @map("sender_type")
  content        String
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now()) @map("created_at")

  conversation ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("chat_messages")
}

model KnowledgeBase {
  id          String              @id @default(uuid())
  title       String
  content     String
  contentType KnowledgeContentType @map("content_type")
  productId   String?             @map("product_id")
  tags        String[]
  slug        String              @unique
  isPublished Boolean             @default(true) @map("is_published")
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  product Product? @relation(fields: [productId], references: [id])

  @@index([isPublished, contentType])
  @@map("knowledge_base")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revoked])
  @@index([token])
  @@map("refresh_tokens")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  oldValues  Json?    @map("old_values")
  newValues  Json?    @map("new_values")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@index([userId, entityType, entityId])
  @@index([createdAt(sort: Desc)])
  @@map("audit_logs")
}

model LandingPage {
  id             String   @id @default(uuid())
  heroTitle      String   @map("hero_title")
  heroSubtitle   String   @map("hero_subtitle")
  heroCtaText    String   @map("hero_cta_text")
  heroCtaLink    String   @map("hero_cta_link")
  heroImage      String?  @map("hero_image")
  features       Json     @default("[]")
  testimonials   Json     @default("[]")
  seoTitle       String?  @map("seo_title")
  seoDescription String?  @map("seo_description")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("landing_page")
}

model BlogPost {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  content     String
  excerpt     String?
  coverImage  String?  @map("cover_image")
  author      String
  category    String
  tags        String[]
  isPublished Boolean  @default(false) @map("is_published")
  likes       Int      @default(0)
  viewCount   Int      @default(0) @map("view_count")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  comments BlogComment[]

  @@index([isPublished, createdAt(sort: Desc)])
  @@map("blog_posts")
}

model BlogComment {
  id         String   @id @default(uuid())
  postId     String   @map("post_id")
  userId     String   @map("user_id")
  content    String
  isApproved Boolean  @default(true) @map("is_approved")
  createdAt  DateTime @default(now()) @map("created_at")

  post BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
  @@map("blog_comments")
}

model Media {
  id         String   @id @default(uuid())
  filename   String
  url        String
  mimeType   String   @map("mime_type")
  size       Int
  width      Int?
  height     Int?
  uploadedBy String   @map("uploaded_by")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("media")
}

model SiteSettings {
  id                String   @id @default(uuid())
  siteName          String   @map("site_name")
  tagline           String?
  description       String?
  logo              String?
  favicon           String?
  primaryColor      String   @default("#4F46E5") @map("primary_color")
  socialLinks       Json     @default("{}") @map("social_links")
  googleAnalyticsId String?  @map("google_analytics_id")
  customCss         String?  @map("custom_css")
  footerText        String?  @map("footer_text")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}