# ============================================
# DevGlobal Hub - Environment Variables
# ============================================

# Node Environment
NODE_ENV=development

# Database (PostgreSQL with pgvector)
DATABASE_URL=postgresql://devglobal:devglobal123@localhost:5432/devglobal_hub?schema=public

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT Configuration
JWT_ACCESS_SECRET=your-access-secret-key-min-32-chars-long
JWT_REFRESH_SECRET=your-refresh-secret-key-min-32-chars-long
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key

# Resend Email
RESEND_API_KEY=re_your-resend-api-key
EMAIL_FROM_ADDRESS=support@devglobalhub.com
EMAIL_FROM_NAME=DevGlobal Hub

# Cloudflare R2 Storage
CLOUDFLARE_R2_ACCESS_KEY=your-r2-access-key
CLOUDFLARE_R2_SECRET_KEY=your-r2-secret-key
CLOUDFLARE_R2_ENDPOINT=https://your-account.r2.cloudflarestorage.com
CLOUDFLARE_R2_BUCKET=devglobal-hub
CLOUDFLARE_R2_PUBLIC_URL=https://cdn.devglobalhub.com

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:4000

# Backend Configuration
BACKEND_PORT=4000
BACKEND_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info

# Feature Flags
ENABLE_AI_FEATURES=true
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_LICENSE_CHECK=true